# --- SERVER SETTINGS ---
PROJECT_NAME="FastAPI Voice Agent"
ENVIRONMENT="development"
HOST="0.0.0.0"
PORT=8000

# --- LLM SETTINGS (Ollama) ---
OLLAMA_BASE_URL="http://localhost:11434/api/chat"
LLM_MODEL="llama3.3:1b"

# --- STT SETTINGS (Faster Whisper) ---
STT_MODEL_SIZE="large-v3-turbo"
STT_DEVICE="cuda"  # Change to "cpu" if you don't have an NVIDIA GPU

# --- TTS SETTINGS (XTTS v2) ---
TTS_SPEAKER_REF_PATH="assets/speaker_ref.wav"
TTS_DEVICE="cuda"  # Change to "cpu" if you don't have an NVIDIA GPU