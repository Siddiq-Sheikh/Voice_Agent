# ==========================================
# Voice Assistant Environment Variables
# ==========================================

# --- Cloud AI Providers ---
# Required for the Groq fallback LLM and the Vision model
GROQ_API_KEY=gsk_your_actual_api_key_goes_here

# --- PostgreSQL Database (For the RAG Engine) ---
# Update these with your local or cloud database credentials
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=your_company_db_name

# --- Local AI (Ollama) ---
# You hardcoded this in the script, but it is best practice to keep it here!
OLLAMA_URL=http://localhost:11434/api/chat

# --- App Settings (Optional but handy) ---
ENVIRONMENT=development
DEBUG=True